    stack<product> mycart;
};

// ================== Linked List cart ==================

struct cart_Node {
    product item;
    cart_Node* link;
    cart_Node(product x) { item = x; link = NULL; }
};

struct cart {
    cart_Node* head;
    cart() { head = NULL; }

    void addItem(product x) {
        cart_Node* newItem = new cart_Node(x);
        newItem->link = head;
        head = newItem;
    }

    void removeItem(string barcode) {
        if (!head) return;
        if (head->item.barcode == barcode) {
            cart_Node* check = head;
            head = head->link;
            delete check;
            return;
        }

        cart_Node* currentItem = head;
        while (currentItem->link != nullptr && currentItem->link->item.barcode != barcode)
            currentItem = currentItem->link;

        if (currentItem->link != nullptr && currentItem->link->item.barcode == barcode) {
            cart_Node* toDelete = currentItem->link;
            currentItem->link = toDelete->link;
            delete toDelete;
        }
    }

    void print() {
        cart_Node* current = head;
        if (!current) { cout << "Cart empty\n"; return; }
        cout << current->item.name << endl;
        cout << current->item.barcode << endl;
        cout << current->item.price << endl;
        current = current->link;
    }
};

// ================== Hash Table ==================

struct ProductHT {
    int barcode;
    string name;
    double price;
    int quantity;
};

class HashTable {
private:
    const static int TABLE_SIZE = 10;
    vector<list<ProductHT>> table;

    int hashFunction(int barcode) { return barcode % TABLE_SIZE; }

public:
    HashTable() : table(TABLE_SIZE) {}

    void insert(ProductHT p) {
        int index = hashFunction(p.barcode);
        table[index].push_back(p);
    }

    ProductHT* search(int barcode) {
        int index = hashFunction(barcode);
        for (auto& p : table[index]) {
            if (p.barcode == barcode) return &p;
        }
        return nullptr;
    }

    bool remove(int barcode) {
        int index = hashFunction(barcode);
        for (auto it = table[index].begin(); it != table[index].end(); ++it) {
            if (it->barcode == barcode) { table[index].erase(it); return true; }
        }
        return false;
    }

    bool update(int barcode, string newName, double newPrice, int newQuantity) {
        int index = hashFunction(barcode);
        for (auto& p : table[index]) {
            if (p.barcode == barcode) {
                p.name = newName;
                p.price = newPrice;
                p.quantity = newQuantity;
                return true;
            }
        }
        return false;
    }

    void print() {
        for (int i = 0; i < TABLE_SIZE; ++i) {
            cout << "Index " << i << ": ";
            for (const auto& product : table[i])
                cout << "(" << product.barcode << ", " << product.name << ", " << product.price << ", " << product.quantity << ") ";
            cout << endl;
        }
    }
};

