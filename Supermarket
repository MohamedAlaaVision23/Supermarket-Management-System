// ================== BST Product ==================
// Binary Search Tree to store products sorted by price

struct Product
{
    int barcode;          // Unique product barcode
    string name;          // Product name
    float price;          // Product price
    string expiry_Date;   // Expiration date
};

struct Node
{
    Product data;         // Product data stored in node
    Node* left;           // Pointer to left child (lower price)
    Node* right;          // Pointer to right child (higher or equal price)

    Node(const Product& p) // Node constructor
    {
        data = p;         // Store product data
        left = nullptr;   // Initialize left child
        right = nullptr;  // Initialize right child
    }
};

class ProductBST
{
private:
    Node* root;           // Pointer to tree root
    int node_count;       // Number of products in tree

    // Recursive helper for insertion
    Node* insertRec(Node* node, const Product& p)
    {
        if (node == nullptr) // Found empty spot
        {
            node_count++;    // Increment count
            return new Node(p); // Create new node
        }

        // Go left if price is lower
        if (p.price < node->data.price)
        {
            node->left = insertRec(node->left, p);
        }
        else // Go right if price is higher or equal
        {
            node->right = insertRec(node->right, p);
        }

        return node;
    }

    // Find minimum price node (leftmost)
    Node* findMin(Node* node) const
    {
        if (node == nullptr) return nullptr;
        while (node->left != nullptr)
        {
            node = node->left;
        }
        return node;
    }

    // Find maximum price node (rightmost)
    Node* findMax(Node* node) const
    {
        if (node == nullptr) return nullptr;
        while (node->right != nullptr)
        {
            node = node->right;
        }
        return node;
    }

    // Recursive remove by price
    Node* removeRec(Node* node, float price, bool& removed)
    {
        if (node == nullptr) return nullptr;

        if (price < node->data.price)
        {
            node->left = removeRec(node->left, price, removed);
        }
        else if (price > node->data.price)
        {
            node->right = removeRec(node->right, price, removed);
        }
        else
        {
            removed = true;

            // Case 1: leaf node
            if (node->left == nullptr && node->right == nullptr)
            {
                delete node;
                node_count--;
                return nullptr;
            }
            // Case 2: one child
            else if (node->left == nullptr)
            {
                Node* temp = node->right;
                delete node;
                node_count--;
                return temp;
            }
            else if (node->right == nullptr)
            {
                Node* temp = node->left;
                delete node;
                node_count--;
                return temp;
            }
            // Case 3: two children
            else
            {
                Node* minNode = findMin(node->right);
                node->data = minNode->data;
                node->right = removeRec(node->right, minNode->data.price, removed);
            }
        }

        return node;
    }

    // Recursive search by price
    Node* findRec(Node* node, float price) const
    {
        if (node == nullptr) return nullptr;

        if (price == node->data.price) return node;
        else if (price < node->data.price) return findRec(node->left, price);
        else return findRec(node->right, price);
    }

    // In-order print
    void inOrderPrint(Node* node) const
    {
        if (node == nullptr) return;

        inOrderPrint(node->left);

        cout << "Product: " << node->data.name
            << " | Price: " << node->data.price
            << " | Barcode: " << node->data.barcode
            << " | Expiry: " << node->data.expiry_Date << endl;

        inOrderPrint(node->right);
    }

    // Tree height
    int treeHeight(Node* node) const
    {
        if (node == nullptr) return 0;

        int leftH = treeHeight(node->left);
        int rightH = treeHeight(node->right);

        return (leftH > rightH ? leftH : rightH) + 1;
    }

    // Clear tree
    void clearRec(Node* node)
    {
        if (node == nullptr) return;

        clearRec(node->left);
        clearRec(node->right);
        delete node;
    }

public:
    ProductBST() { root = nullptr; node_count = 0; }
    ~ProductBST() { clearRec(root); }

    bool insert(const Product& p)
    {
        if (p.barcode <= 0 || p.name.empty() || p.price < 0 || p.expiry_Date.empty())
        {
            cout << "Invalid product data, insertion failed.\n";
            return false;
        }

        int old_count = node_count;
        root = insertRec(root, p);
        return node_count > old_count;
    }

    bool remove(float price)
    {
        bool removed = false;
        root = removeRec(root, price, removed);
        return removed;
    }

    Product* findProductByPrice(float price) const
    {
        Node* node = findRec(root, price);
        if (node != nullptr) return &(node->data);
        return nullptr;
    }

    void displaySorted() const
    {
        cout << "\n== BST Products (Sorted by Price) ==\n";
        if (root == nullptr)
        {
            cout << "No products in BST.\n";
            return;
        }
        inOrderPrint(root);
    }

    void displayStatistics() const
    {
        cout << "\n===== BST Statistics =====\n";
        cout << "Number of products: " << node_count << endl;
        cout << "Approx. tree height: " << treeHeight(root) << endl;

        Node* cheap = findMin(root);
        Node* expensive = findMax(root);

        if (cheap != nullptr)
            cout << "Cheapest product: " << cheap->data.name << " - " << cheap->data.price << endl;
        if (expensive != nullptr)
            cout << "Most expensive product: " << expensive->data.name << " - " << expensive->data.price << endl;
    }

    bool isEmpty() const { return root == nullptr; }
    int size() const { return node_count; }
};

// ================== Queue ==================
// Customer queue (FIFO)

struct QueueNode {
    int customerID;
    QueueNode* next;
    QueueNode(int id) : customerID(id), next(nullptr) {}
};

class CustomerQueue {
private:
    QueueNode* front;
    QueueNode* rear;

public:
    CustomerQueue() : front(nullptr), rear(nullptr) {}
    ~CustomerQueue() {
        while (front != nullptr) {
            QueueNode* temp = front;
            front = front->next;
            delete temp;
        }
        rear = nullptr;
    }

    bool isEmpty() const { return front == nullptr; }

    void enqueue(int customerID) {
        QueueNode* newNode = new QueueNode(customerID);
        if (isEmpty()) {
            front = rear = newNode;
        } else {
            rear->next = newNode;
            rear = newNode;
        }
        cout << customerID << " enqueued\n";
    }

    int dequeue() {
        if (isEmpty()) { cout << "Queue is empty\n"; return -1; }
        QueueNode* temp = front;
        int dequeuedID = temp->customerID;
        front = front->next;
        if (front == nullptr) rear = nullptr;
        delete temp;
        cout << dequeuedID << " dequeued\n";
        return dequeuedID;
    }

    void displayQueue() const {
        if (isEmpty()) { cout << "Queue is empty\n"; return; }
        QueueNode* current = front;
        while (current != nullptr) {
            cout << current->customerID << " ";
            current = current->next;
        }
        cout << endl;
    }
};

// ================== Stack + small product ==================

struct product
{
    string name, barcode;
    float price;
};

template<class t>
class stack {
private:
    struct node
    {
        t item;
        node* next;
    };
    node* top, * cur;
public:
    stack() { top = NULL; }
    ~stack() {
        while (!is_empty()) pop();
    }

    void push(t NewItem)
    {
        node* newitemptr = new node;
        newitemptr->item = NewItem;
        newitemptr->next = top;
        top = newitemptr;
    }

    bool is_empty() { return top == NULL; }

    void pop()
    {
        if (is_empty()) cout << "No item to pop\n";
        else {
            node* temp = top;
            top = top->next;
            delete temp;
        }
    }

    void pop(t& stacktop)
    {
        if (is_empty()) cout << "No item to pop\n";
        else {
            stacktop = top->item;
            node* temp = top;
            top = top->next;
            delete temp;
        }
    }

    t peek()
    {
        if (is_empty()) { cout << "No item\n"; return t(); }
        return top->item;
    }

    void print()
    {
        cur = top;
        cout << "Items in cart: [";
        while (cur != NULL)
        {
            cout << cur->item.name << " ";
            cur = cur->next;
        }
        cout << "]" << endl;
    }
};

